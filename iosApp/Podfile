# Podfile para iosApp
platform :ios, '16.0'

target 'iosApp' do
  use_frameworks!
  
  # Google Sign-In
  pod 'GoogleSignIn', '~> 7.0'
  
  # Kotlin Multiplatform Framework
  # Este pod se genera automáticamente desde el proyecto Kotlin
  pod 'composeApp', :path => '../composeApp'
end

# Configuración post-install para evitar warnings
post_install do |installer|
  readlink_fix_old = 'source="$(readlink "${source}")"'
  readlink_fix_new = <<~'SCRIPT'.strip
    source="$(readlink "${source}")"
    if [[ "$source" != /* ]]; then
      source="$(dirname "${BUILT_PRODUCTS_DIR}/$1")/${source}"
    fi
  SCRIPT

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
    end

    if target.respond_to?(:product_type) && target.product_type == 'com.apple.product-type.bundle'
      target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ''
        config.build_settings['CODE_SIGN_IDENTITY'] = ''
      end
    end
  end
  
  # Fix del bug de rsync al ARCHIVAR: el script generado *-frameworks.sh resuelve
  # symlinks relativos con readlink y rsync no los encuentra
  # ("framework: stat: No such file or directory"). Parcheamos el .sh en disco
  # porque el loop de arriba solo toca build phases inline, no los scripts generados.
  Dir.glob(File.join(__dir__, 'Pods', 'Target Support Files', '**', '*-frameworks.sh')).each do |script|
    contents = File.read(script)
    if contents.include?(readlink_fix_old) && !contents.include?(readlink_fix_new)
      contents = contents.sub(readlink_fix_old, readlink_fix_new)
      File.write(script, contents)
    end
  end

  # Agregar PATH para que Xcode encuentre CocoaPods y otros comandos de Homebrew
  # Modificar scripts de build para que carguen .xcode.env
  xcode_env_path = File.join(__dir__, '.xcode.env')
  if File.exist?(xcode_env_path)
    source_command = "if [ -f \"#{xcode_env_path}\" ]; then source \"#{xcode_env_path}\"; fi\n"
    
    installer.pods_project.targets.each do |target|
      target.build_phases.each do |phase|
        if phase.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
          phase.shell_script = source_command + phase.shell_script
          if phase.shell_script.include?(readlink_fix_old)
            phase.shell_script = phase.shell_script.gsub(readlink_fix_old, readlink_fix_new)
          end
        end
      end
    end
  end
end
